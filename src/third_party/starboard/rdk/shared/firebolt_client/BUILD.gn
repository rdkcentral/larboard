declare_args() {
  firebolt_client_version_major = 0
  firebolt_client_version_minor = 5
  firebolt_client_version_patch = 5

  firebolt_transport_version_major = 1
  firebolt_transport_version_minor = 1
  firebolt_transport_version_patch = 6

  legacy_rpc_v1 = true
  use_system_firebolt_libs = false
}

firebolt_client_version_string = "${firebolt_client_version_major}.${firebolt_client_version_minor}.${firebolt_client_version_patch}"
firebolt_transport_version_string = "${firebolt_transport_version_major}.${firebolt_transport_version_minor}.${firebolt_transport_version_patch}"

template("generate_export_header") {
  action(target_name) {
    script = "build/generate_export_header.py"
    forward_variables_from(invoker, [ "deps", "visibility" ])
    outputs = [ invoker.output ]
    args = [
      "--output", rebase_path(invoker.output, root_build_dir),
      "--prefix", invoker.prefix,
    ]
  }
}

template("configure_file") {
  action(target_name) {
    script = "build/configure_file.py"
    inputs  = [ invoker.input ]
    outputs = [ invoker.output ]
    _vars = []
    if (defined(invoker.vars)) {
      foreach(v, invoker.vars) {
        _vars += [ "--var", v ]
      }
    }
    args = [
      "--input",  rebase_path(invoker.input,  root_build_dir),
      "--output", rebase_path(invoker.output, root_build_dir),
    ] + _vars
  }
}

configure_file("generate_firebolt_transport_config_header") {
  input  = "//third_party/firebolt-cpp-transport/include/firebolt/config.h.in"
  output = "$target_gen_dir/firebolt/config.h"
  vars   = [
    "FIREBOLT_LEGACY_RPC_V1=${legacy_rpc_v1}",
  ]
}

configure_file("generate_firebolt_transport_version_header") {
  input  = "//third_party/firebolt-cpp-transport/include/firebolt/version.h.in"
  output = "$target_gen_dir/firebolt/transport_version.h"
  vars   = [
    "PROJECT_VERSION_MAJOR=${firebolt_transport_version_major}",
    "PROJECT_VERSION_MINOR=${firebolt_transport_version_minor}",
    "PROJECT_VERSION_PATCH=${firebolt_transport_version_patch}",
    "PROJECT_VERSION=${firebolt_transport_version_string}",
  ]
}

configure_file("generate_firebolt_client_version_header") {
  input  = "//third_party/firebolt-cpp-client/include/firebolt/version.h.in"
  output = "$target_gen_dir/firebolt/client_version.h"
  vars   = [
    "PROJECT_VERSION_MAJOR=${firebolt_client_version_major}",
    "PROJECT_VERSION_MINOR=${firebolt_client_version_minor}",
    "PROJECT_VERSION_PATCH=${firebolt_client_version_patch}",
    "PROJECT_VERSION=${firebolt_client_version_string}",
  ]
}

generate_export_header("generate_firebolt_transport_export_header") {
  output = "$target_gen_dir/firebolt/transport_export.h"
  prefix = "FIREBOLTTRANSPORT"
}

generate_export_header("generate_firebolt_client_export_header") {
  output = "$target_gen_dir/firebolt/client_export.h"
  prefix = "FIREBOLTCLIENT"
}

config("firebolt_client_src_config") {
  include_dirs = [
    "//third_party/firebolt-cpp-client/include",
    "//third_party/firebolt-cpp-client/src",
    "//third_party/firebolt-cpp-transport/include",
    "//third_party/firebolt-cpp-transport/src",
    "$target_gen_dir",
  ]
}

