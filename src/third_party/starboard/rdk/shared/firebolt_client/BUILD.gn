}

config("firebolt_client_from_system") {
  libs = [
    "FireboltClient",
    "FireboltTransport",
  ]
}

group("firebolt_client_group") {
  if (use_system_firebolt_libs) {
    public_configs = [ ":firebolt_client_from_system" ]
  } else {
    public_deps = [ ":firebolt_client" ]
  }
}
